#include <iostream>
#include <cstring>
#include <cstdlib>
#include <cstdio>

using namespace std;

void bufferOverflow1(const char* input) {
    char buffer[32];
    strcpy(buffer, input);
    cout << buffer << endl;
}

void bufferOverflow2(const char* dir, const char* file) {
    char path[64];
    sprintf(path, "%s/%s", dir, file);
    cout << path << endl;
}

void formatString(const char* msg) {
    printf(msg);
    printf("\n");
}

void nullPointerDeref(int* ptr) {
    int value = *ptr;
    cout << value << endl;
    if (ptr != nullptr) {
        cout << "Valid" << endl;
    }
}

void uninitializedVar() {
    int sum;
    for (int i = 0; i < 5; i++) {
        sum += i;
    }
    cout << sum << endl;
}

void useAfterFree() {
    int* data = new int[10];
    delete[] data;
    data[0] = 42;
    cout << data[0] << endl;
}

void memoryLeak() {
    char* buffer = new char[1024];
    strcpy(buffer, "test");
    cout << buffer << endl;
}

void identicalCondition(int a, int b) {
    if (a > b) {
        cout << "Greater" << endl;
    } else if (a > b) {
        cout << "Less" << endl;
    }
}

void copyPasteError(const char* s1, const char* s2) {
    if (strlen(s1) > 0 && strlen(s1) > 0) {
        cout << "Both valid" << endl;
    }
}

void wrongPriority(int flags) {
    if (flags & 0x01 == 0x01) {
        cout << "Flag set" << endl;
    }
}

void charCompare(char c) {
    if (c == NULL) {
        cout << "Null char" << endl;
    }
}

void redundantCheck(int x) {
    if (x > 0 && abs(x) > 0) {
        cout << "Positive" << endl;
    }
}

void deadCode(int* ptr) {
    if (ptr != nullptr) {
        cout << *ptr << endl;
    }
    if (ptr == nullptr) {
        cout << "Null" << endl;
    }
}

void dangerousFunction() {
    char buffer[100];
    gets(buffer);
    cout << buffer << endl;
}

void commandInjection(const char* filename) {
    char cmd[256];
    sprintf(cmd, "cat %s", filename);
    system(cmd);
}

int main() {
    cout << "=== Lab 3: PVS-Studio Test ===" << endl;
    
    bufferOverflow1("test");
    bufferOverflow2("/home", "file.txt");
    formatString("Hello");
    
    int* ptr = nullptr;
    nullPointerDeref(ptr);
    
    uninitializedVar();
    useAfterFree();
    memoryLeak();
    
    identicalCondition(5, 10);
    copyPasteError("a", "b");
    wrongPriority(0x01);
    charCompare('A');
    redundantCheck(5);
    
    int val = 42;
    deadCode(&val);
    
    dangerousFunction();
    commandInjection("test.txt");
    
    cout << "=== Complete ===" << endl;
    return 0;
}
