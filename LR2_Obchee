using namespace std;

// ============================================================================
// ОШИБКА 1: V501 — Одинаковые условия в обеих ветках
// ============================================================================
// ПРОБЛЕМА: В if и else if одинаковое условие (a > b)
// ПОСЛЕДСТВИЯ: Ветка else if никогда не выполнится, логика сломана
// ИСПРАВЛЕНИЕ: Заменить второе условие на (a < b)
// ============================================================================
void compareNumbers(int a, int b) {
    if (a > b) {
        cout << "A больше B" << endl;
    } else if (a > b) { 
        cout << "A меньше B" << endl;
    } else {
        cout << "A равно B" << endl;
    }
}

// ============================================================================
// ОШИБКА 2: V595 — Разыменование указателя до проверки на null
// ============================================================================
//  ПРОБЛЕМА: *ptr используется ДО проверки ptr != nullptr
//  ПОСЛЕДСТВИЯ: Crash программы (Access Violation) при null указателе
//  ИСПРАВЛЕНИЕ: Сначала проверить указатель, потом разыменовывать
// ============================================================================
void processArray(int* arr, int size) {
    int first = arr[0];  
    cout << "First element: " << first << endl;
    
    if (arr != nullptr && size > 0) {
        cout << "Array is valid" << endl;
    }
}

// ============================================================================
// ОШИБКА 3: V535 — Неинициализированная переменная
// ============================================================================
// ПРОБЛЕМА: Переменная result не инициализирована перед использованием
// ПОСЛЕДСТВИЯ: Неопределённое поведение, случайное значение из памяти
// ИСПРАВЛЕНИЕ: Инициализировать переменную при объявлении (int result = 0)
// ============================================================================
void calculateProduct(const vector<int>& numbers) {
    int result; 
    for (int num : numbers) {
        result *= num;  // result содержит мусор!
    }
    cout << "Product: " << result << endl;
}

// ============================================================================
// ОШИБКА 4: V571 — Сравнение несовместимых типов (char с NULL)
// ============================================================================
//  ПРОБЛЕМА: char сравнивается с NULL (который для указателей)
// ПОСЛЕДСТВИЯ: Логическая ошибка, условие всегда ложно
// ИСПРАВЛЕНИЕ: Сравнивать с '\0' (нулевой символ)
// ============================================================================
void checkCharacter(char c) {
    if (c == NULL) {  
        cout << "Character is null" << endl;
    }
}

// ============================================================================
// ОШИБКА 5: V597 — Неверный приоритет операторов
// ============================================================================
// ПРОБЛЕМА: == выполняется раньше чем &, условие работает неверно
//  ПОСЛЕДСТВИЯ: Флаг проверяется неправильно, логика сломана
//  ИСПРАВЛЕНИЕ: Добавить скобки: (flags & MASK) == MASK
// ============================================================================
void checkPermissions(int flags) {
    const int READ_FLAG = 0x01;
    const int WRITE_FLAG = 0x02;
    
    if (flags & READ_FLAG == READ_FLAG) { 
        cout << "Read permission granted" << endl;
    }
}

// ============================================================================
// ОШИБКА 6: V501 — Copy-Paste ошибка (одинаковые операнды)
// ============================================================================
// ПРОБЛЕМА: str1.length() проверяется дважды вместо str2
// ПОСЛЕДСТВИЯ: Вторая строка не проверяется, логика неверна
// ИСПРАВЛЕНИЕ: Заменить второе str1 на str2
// ============================================================================
void validateStrings(const string& str1, const string& str2) {
    if (str1.length() > 0 && str1.length() > 0) {  
        cout << "Both strings are not empty" << endl;
    }
}

// ============================================================================
// ОШИБКА 7: V547 — Мёртвый код (проверка после использования)
// ============================================================================
//  ПРОБЛЕМА: Указатель проверяется на null после того как уже использован
// ПОСЛЕДСТВИЯ: Проверка бессмысленна, код никогда не выполнится
// ИСПРАВЛЕНИЕ: Переместить проверку перед использованием или убрать
// ============================================================================
void processData(int* data) {
    if (data != nullptr) {
        cout << "Data value: " << *data << endl;
    }
    if (data == nullptr) {  
        cout << "Data is null" << endl;  // Эта строка никогда не выполнится
    }
}

// ============================================================================
// ОШИБКА 8: V609 — Лишний вызов функции (модуль положительного числа)
// ============================================================================
// ПРОБЛЕМА: abs(x) вызывается после проверки x > 0
// GОСЛЕДСТВИЯ: Лишние вычисления, код менее читаемый
// ИСПРАВЛЕНИЕ: Убрать abs(), оставить просто x
// ============================================================================
void validatePositive(int x) {
    if (x > 0 && abs(x) > 0) { 
        cout << "X is positive" << endl;
    }
}

