// MAIN ФУНКЦИЯ
// ============================================================================
int main() {
    cout << "=== PVS-Studio Demo (WITH ERRORS) ===" << endl << endl;
    
    compareNumbers(5, 10);
    
    int arr[] = {1, 2, 3, 4, 5};
    processArray(arr, 5);
    
    vector<int> nums = {2, 3, 4};
    calculateProduct(nums);
    
    checkCharacter('A');
    checkPermissions(0x03);
    validateStrings("Hello", "World");
    
    int data = 42;
    processData(&data);
    
    validatePositive(10);
    
    cout << endl << "=== Demo Complete ===" << endl;
    return 0;
}
